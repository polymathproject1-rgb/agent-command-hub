# Nova outbound automation
NOVA_OUTBOUND_DAEMON_INTERVAL_MS=300000
NOVA_OUTBOUND_BATCH_SIZE=5
NOVA_OUTBOUND_SEND_BATCH_SIZE=10
NOVA_OUTBOUND_AUTO_CREATE=true
NOVA_OUTBOUND_AUTO_RESEARCH=true
NOVA_OUTBOUND_AUTO_DRAFT=true
NOVA_OUTBOUND_AUTO_SEND=false
NOVA_OUTBOUND_AUTO_APPROVE_THRESHOLD=0.80
NOVA_OUTBOUND_STALLED_MINUTES=15
NOVA_OUTBOUND_MAX_RETRIES=3
NOVA_OUTBOUND_ENABLE_AI_LOGS=true
