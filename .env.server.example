# Backend proxy (do NOT expose these in frontend env)
AGENT_COMMAND_API_URL=https://smmquuwzdininxleloom.supabase.co/functions/v1/ai-tasks
AGENT_COMMAND_WEBHOOK_SECRET=your-webhook-secret
DEFAULT_AGENT_NAME=Rei
DEFAULT_AGENT_EMOJI=🦐
PORT=8787
TASK_POLL_INTERVAL_MS=60000
PROGRESS_UPDATE_INTERVAL_MS=480000
STALL_ESCALATION_INTERVAL_MS=960000
